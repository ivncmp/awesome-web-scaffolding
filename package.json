{
  "name": "awesome-web-scaffolding",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite frontend",
    "build": "tsc -b frontend && vite build frontend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deno:check": "$HOME/.deno/bin/deno check --config backend/supabase/functions/deno.json backend/supabase/functions/*/index.ts backend/supabase/functions/_shared/*.ts",
    "deno:lint": "$HOME/.deno/bin/deno lint --config backend/supabase/functions/deno.json backend/supabase/functions/*/index.ts backend/supabase/functions/_shared/*.ts",
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx,js,jsx,css,json}\" \"backend/**/*.ts\"",
    "format:check": "prettier --check \"frontend/src/**/*.{ts,tsx,js,jsx,css,json}\" \"backend/**/*.ts\"",
    "preview": "vite preview frontend",
    "test": "vitest --config frontend/vitest.config.ts",
    "test:ui": "vitest --ui --config frontend/vitest.config.ts",
    "test:run": "vitest run --config frontend/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config frontend/vitest.config.ts",
    "prepare": "husky",
    "check": "eslint --fix . && prettier --write --check \"frontend/src/**/*.{ts,tsx,js,jsx,css,json}\" \"backend/**/*.ts\" && vitest run --config frontend/vitest.config.ts && $HOME/.deno/bin/deno lint --config backend/supabase/functions/deno.json backend/supabase/functions/*/index.ts backend/supabase/functions/_shared/*.ts && $HOME/.deno/bin/deno check --config backend/supabase/functions/deno.json backend/supabase/functions/*/index.ts backend/supabase/functions/_shared/*.ts && tsc -b frontend && vite build frontend && npx -y react-doctor@latest .",
    "deploy-backend": "echo 'Add your Supabase functions deploy commands here'"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.1",
    "@supabase/supabase-js": "^2.49.8",
    "@tailwindcss/vite": "^4.1.7",
    "@tanstack/react-query": "^5.76.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.6.0",
    "react-router-dom": "^7.6.0",
    "tailwindcss": "^4.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tanstack/react-query-devtools": "^5.76.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react-swc": "^3.9.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json}": [
      "prettier --write"
    ]
  }
}
